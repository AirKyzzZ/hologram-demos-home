# -------- Runtime --------
APP_PORT=3003
NODE_ENV=production
LOG_LEVEL=info

# -------- VS Agent sidecar --------
# Admin URL of the vs-agent container this bot talks to (inside the pod network).
VS_AGENT_ADMIN_URL=http://vs-agent:3000
# Public DIDComm endpoint published by the vs-agent (used by the Hologram app).
AGENT_PUBLIC_URL=https://dm.my-bot.example.com
AGENT_LABEL=Template Bot

# -------- Agent pack --------
AGENT_PACK_PATH=/app/agent-packs/template/agent-pack.yaml
AGENT_ID=template
AGENT_DISPLAY_NAME=Template Bot
AGENT_DEFAULT_LANGUAGE=en

# -------- Health --------
HEALTH_PROBE_PATH=/health
READY_PROBE_PATH=/ready
