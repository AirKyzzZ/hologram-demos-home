# Copy to secrets.local.env and fill in real values.
# This file is gitignored — do NOT check the real one in.
#
# Each line becomes a key in the `demos-secrets` Kubernetes secret.
# Helm values files reference these keys via `secretKeyRef`.

# ---- VS Agent wallet keys (one per bot) ----
TWITTER_BOT_WALLET_KEY=change-me-random-32-bytes
WHISPER_BOT_WALLET_KEY=change-me-random-32-bytes
OPENCLAW_WALLET_KEY=change-me-random-32-bytes

# ---- Postgres (shared) ----
POSTGRES_USER=holo
POSTGRES_PASSWORD=change-me
POSTGRES_DB=holo

# ---- LLM providers ----
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ---- Twitter bot credentials ----
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_HANDLE=

# ---- Object storage (optional) ----
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me
