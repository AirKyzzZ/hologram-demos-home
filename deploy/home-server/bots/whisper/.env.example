# Per-bot environment for the Whisper bot.
# Copy to bots/whisper/.env and fill in the OpenAI key before `make up`.

# ── OpenAI Whisper ───────────────────────────────────────────────
# Required. Get one from coworker or https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Runtime ──────────────────────────────────────────────────────
APP_PORT=3000
LOG_LEVEL=4
AGENT_PACK_PATH=/app/agent-packs/whisper/agent-pack.yaml
AGENT_MEMORY_BACKEND=redis
AGENT_MEMORY_WINDOW=2
VS_AGENT_STATS_ENABLED=false

# ── LLM (unused by whisper bot but required by generic agent boot) ──
# The whisper bot does NOT call the LLM — audio goes straight to Whisper.
# These values keep the generic agent's config loader happy.
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=256
