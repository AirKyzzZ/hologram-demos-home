# Per-bot environment for HoloClaw (multiplayer AI workspace).
# This file is the ONLY place your LLM keys + encryption secret live.
# Never commit the real .env — it's gitignored.

# --- LLM ---
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=2048
# Uncomment for OpenAI-compatible providers (Kimi, DeepSeek, Groq, Together AI, …)
# OPENAI_BASE_URL=https://api.moonshot.cn/v1

# --- Anthropic (if LLM_PROVIDER=anthropic) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Credential encryption (REQUIRED for BYOMCP) ---
# Generate with: openssl rand -hex 32
# Used to encrypt per-workspace MCP server headers (tokens, API keys).
# If this changes, every stored BYOMCP server must be re-added.
MCP_CONFIG_ENCRYPTION_KEY=change-me-openssl-rand-hex-32

# --- HoloClaw workspace config ---
# Optional — the agent-pack defaults are multi-tenant with sensible limits.
# HOLOCLAW_MULTI_TENANT=true
# HOLOCLAW_MAX_WORKSPACES_PER_OWNER=10
# HOLOCLAW_INVITE_TTL_HOURS=168
# HOLOCLAW_INVITE_DEFAULT_ROLE=collaborator
# HOLOCLAW_LIVE_FEED_ENABLED=true
# HOLOCLAW_LIVE_FEED_VERBOSITY=verbose
# HOLOCLAW_WORKSPACE_TURN_LIMIT_HOURLY=60

# --- Runtime ---
LOG_LEVEL=info
AGENT_PACK_PATH=/app/agent-packs/holoclaw/agent-pack.yaml
AGENT_MEMORY_BACKEND=redis
AGENT_MEMORY_WINDOW=20
VS_AGENT_STATS_ENABLED=false

# --- Auth (HoloClaw MVP runs open; uncomment to require credentials) ---
# AUTH_REQUIRED=false
# CREDENTIAL_DEFINITION_ID=did:web:...
# USER_IDENTITY_ATTRIBUTE=email
# ROLES_ATTRIBUTE=roles
