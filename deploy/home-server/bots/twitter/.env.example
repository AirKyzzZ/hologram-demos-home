# Per-bot environment for the Twitter bot.
# This file is the ONLY place your Twitter + LLM keys live.
# Never commit the real .env — it's gitignored.

# --- LLM ---
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.8
OPENAI_MAX_TOKENS=500

# --- Twitter API (OAuth 1.0a) ---
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_HANDLE=
DAILY_POST_BUDGET=17

# --- Runtime ---
LOG_LEVEL=info
AGENT_PACK_PATH=/app/agent-packs/hologram-welcome/agent-pack.yaml
AGENT_MEMORY_BACKEND=redis
AGENT_MEMORY_WINDOW=20
VS_AGENT_STATS_ENABLED=false
