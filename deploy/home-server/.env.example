# ----- Shared stack config -----
# Tailscale FQDN of the host machine — used by bots to build public URLs.
TAILSCALE_FQDN=home-server.taila251a3.ts.net
PUBLIC_BASE_URL=https://home-server.taila251a3.ts.net

# ----- Shared postgres -----
POSTGRES_USER=holo
POSTGRES_PASSWORD=change-me-pick-a-strong-one
POSTGRES_DB=holo

# ----- Shared minio (object storage for media) -----
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-minio

# ----- Per-bot wallet keys -----
# These are the Credo wallet encryption keys for each bot's vs-agent.
# Generate random 32-byte base64 values — NEVER change them after the
# bot is running, or you'll invalidate every previously issued invitation.
# Quick generate:  openssl rand -base64 32
TWITTER_AGENT_WALLET_KEY=change-me-openssl-rand-base64-32
WHISPER_AGENT_WALLET_KEY=change-me-openssl-rand-base64-32
OPENCLAW_AGENT_WALLET_KEY=change-me-openssl-rand-base64-32
